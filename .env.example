# Crossroads Compass — Local Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Vedic Astrology API (external, paid — section 16.1) ───────────────────
VEDIC_API_URL=http://144.76.78.183:9000/api/v1
VEDIC_API_KEY=

# ─── Human Design ephemeris files (section 16.2) ──────────────────────────
# Download required .se1 files from https://www.astro.com/ftp/swisseph/ephe/
# and place them in ./ephe/
EPHE_PATH=./ephe

# ─── Database ──────────────────────────────────────────────────────────────
# Local dev uses SQLite. For production, switch to postgresql://...
DATABASE_URL=file:./prisma/dev.db

# ─── Stripe ────────────────────────────────────────────────────────────────
# Optional until task #11 (real Stripe). Mock payment service is active while empty.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email via Resend ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase (PDF report storage) ────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# ─── Upstash Redis (KV cache for chart data) ───────────────────────────────
# Free tier: https://console.upstash.com — create a Redis database
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Gemini AI ─────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── App URL ──────────────────────────────────────────────────────────────
# Used by cron routes to build absolute URLs. Defaults to NEXTAUTH_URL if unset.
APP_URL=http://localhost:3000

# ─── Cron authentication (set in Vercel; leave blank locally) ─────────────
CRON_SECRET=
