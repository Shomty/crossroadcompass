{
  "name": "cc-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "download-ephe": "bash scripts/download-ephe.sh",
    "security:scan-secrets": "bash scripts/scan-secrets.sh",
    "security:scan-tracked": "git --no-pager grep -nE 'AIza[0-9A-Za-z_-]{20,}|GOCSPX-[0-9A-Za-z_-]{10,}|sk_(live|test)_[0-9A-Za-z]{10,}|AKIA[0-9A-Z]{16}|xox[baprs]-[0-9A-Za-z-]{10,}|-----BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY-----' -- . ':(exclude).env' ':(exclude).env.local' || true"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.0",
    "@react-email/components": "^1.0.9",
    "@prisma/client": "^7.4.2",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/redis": "^1.36.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openhumandesign-library": "github:nikolamilenkovic/openhumandesign-library",
    "prisma": "^7.4.2",
    "puppeteer": "^24.37.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "tz-lookup": "^6.1.25",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/tz-lookup": "^6.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
