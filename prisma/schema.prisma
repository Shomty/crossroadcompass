// Crossroads Compass - Prisma Schema
// Personal data is subject to GDPR. Deletion cascades from User. See copilot-instructions section 17.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// AUTH (Auth.js / NextAuth v5 required models)
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(USER)

  accounts     Account[]
  sessions     Session[]
  birthProfile BirthProfile?
  transits     Transit[]
  dashas       Dasha[]
  insights     Insight[]
  bookings     ConsultationBooking[]
  subscription Subscription?
  reportPurchases ReportPurchase[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// BIRTH PROFILE & CHART DATA
// See copilot-instructions sections 16, 17, 18 for caching rules.
// ---------------------------------------------------------------------------

model BirthProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Birth data — changing any field bumps profileVersion
  birthName      String
  birthDate      DateTime
  birthTimeKnown Boolean  @default(true)
  birthHour      Int?     // 0-23; null when birthTimeKnown = false (OB-04)
  birthMinute    Int?     // 0-59; null when birthTimeKnown = false (OB-04)
  birthCity      String
  birthCountry   String
  latitude       Float
  longitude      Float
  timezone       String   // IANA timezone e.g. "Europe/Belgrade" — for display only; HD library uses UTC directly

  // Versioning — bumped atomically on birth data change (sections 18, 19)
  profileVersion Int @default(1)

  // Gender — used in HD chart context and personalised report language
  gender String? // "male" | "female" | "other" | null (prefer not to say)

  // Human Design chart — local library (sections 16.2, 18.1)
  // LICENSE PENDING: requires Swiss Ephemeris professional license before go-live
  chartDataHumanDesign  Json?
  hdProfileVersion    Int? // profileVersion at time of last HD calculation (18.1)
  vedicProfileVersion Int? // profileVersion at time of last Vedic fetch (18.2)

  // Typed HD columns for fast indexed querying
  hdType             String?  // Generator | Manifesting Generator | Projector | Manifestor | Reflector
  hdStrategy         String?
  hdAuthority        String?  // Emotional | Sacral | Splenic | Ego | Self-Projected | Mental | Lunar
  hdProfile          String?  // e.g. "1/3"
  hdDefinition       String?  // Single | Split | Triple Split | Quadruple Split | None
  hdIncarnationCross String?
  hdDefinedCenters   String? // JSON-encoded string[] — SQLite has no native arrays
  hdUndefinedCenters String? // JSON-encoded string[]
  hdActiveChannels   String? // JSON-encoded Channel[]
  hdActiveGates      String? // JSON-encoded number[]
  hdInsights         String? // JSON-encoded Record<"type"|"strategy"|"authority"|"profile", {headline,body,practicalTip}>

  // Vedic natal chart — external API (sections 16.1, 18.2)
  // DECISION NEEDED: confirm typed columns once API response shape is confirmed with Milosh
  chartDataVedic Json?

  // Observation location — used for transit/planet position fetch
  // Null = fall back to birth location
  observationLatitude  Float?
  observationLongitude Float?
  observationCity      String? // human-readable label e.g. "Belgrade, Serbia"

  // Onboarding intake (OB-05)
  intakeLifeSituation String?
  intakePrimaryFocus  String?
  intakeWantsClarity  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("birth_profiles")
}

// ---------------------------------------------------------------------------
// TRANSITS — section 18.3 — one row per user per calendar day
// ---------------------------------------------------------------------------

model Transit {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // one row per user per calendar day — compare date portion only
  data      Json
  fetchedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("transits")
}

// ---------------------------------------------------------------------------
// DASHAS — section 18.4 — fetched once; deleted when birth data changes
// ---------------------------------------------------------------------------

enum DashaLevel {
  MAHADASHA
  ANTARDASHA
}

model Dasha {
  id         String     @id @default(cuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  planetName String
  level      DashaLevel
  fetchedAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startDate, endDate])
  @@map("dashas")
}

// ---------------------------------------------------------------------------
// INSIGHTS — DAILY / WEEKLY / MONTHLY generated content (sections 5.2, 6)
// ---------------------------------------------------------------------------

enum InsightType {
  DAILY
  WEEKLY
  MONTHLY
  INITIAL  // foundation report insight (report/generate)
  DASHA    // persisted dasha card back-face insight; periodDate = mahadasha startDate
  CAREER   // VIP life reading — career/vocation (D1 + D10 + HD); periodDate = epoch
  LOVE     // VIP life reading — relationships/love (D1 + D9 + HD); periodDate = epoch
  HEALTH   // VIP life reading — vitality/wellbeing (HD); periodDate = epoch
  JYOTISH  // VIP life reading — comprehensive Vedic synthesis via Gem (D1+D9+D10+Dasha); periodDate = epoch
  MUHURTA_WEEKLY  // cached muhurta AI insight; periodDate = Monday of that week
}

model Insight {
  id         String      @id @default(cuid())
  userId     String
  type       InsightType
  // periodDate semantics:
  //   DAILY   -> specific calendar day
  //   WEEKLY  -> Monday of that week
  //   MONTHLY -> 1st of that month
  periodDate DateTime
  content    String

  generatedAt          DateTime  @default(now())
  reviewedByConsultant Boolean   @default(false) // section 6.3 content review
  reviewedAt           DateTime?
  deliveredAt          DateTime?
  rejectedAt           DateTime?
  rejectedBy           String?
  accuracyRating       Int?      // 1-5 user rating from email poll (section 6.3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodDate])
  @@index([userId, type, periodDate])
  @@map("insights")
}

// ---------------------------------------------------------------------------
// CONSULTATION BOOKINGS — section 5.4
// ---------------------------------------------------------------------------

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ConsultationTier {
  SINGLE_90      // $150 — 90-min session
  VIP_QUARTERLY  // $497 — quarterly package (CB-06)
}

model ConsultationBooking {
  id                 String           @id @default(cuid())
  userId             String
  tier               ConsultationTier
  status             BookingStatus    @default(PENDING)
  scheduledAt        DateTime?
  calendlyEventId    String?          // MVP = external link; future = embedded (CB-03)
  stripePaymentId    String?
  amountCents        Int
  consultantNotes    String?          // CB-05 (Phase 2)
  prepGuideEmailSent Boolean          @default(false) // CB-04 (Phase 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("consultation_bookings")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTIONS — AC-02 — Stripe-backed tiers FREE / CORE / VIP
// ---------------------------------------------------------------------------

enum SubscriptionTier {
  FREE
  CORE // $29/month
  VIP  // $497/quarter
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// ADMIN — Prompt Templates, Audit Log, Feature Flags, System Config
// ---------------------------------------------------------------------------

enum PromptFeature {
  DAILY_INSIGHT
  WEEKLY_FORECAST
  MONTHLY_REPORT
  HD_TIP
  ONBOARDING_REPORT
  WELCOME_EMAIL
  PRESESSION_EMAIL
  TRANSIT_ALERT_EMAIL
  LIFE_READING
  TRANSIT_READING
}

enum AuditActionType {
  INSIGHT_APPROVED
  INSIGHT_REJECTED
  INSIGHT_EDITED
  PROMPT_SAVED
  PROMPT_ROLLED_BACK
  USER_TIER_CHANGED
  USER_CHART_INVALIDATED
  USER_DELETED
  CONSULTATION_STATUS_CHANGED
  CONSULTATION_NOTES_ADDED
  CONFIG_CHANGED
  FEATURE_FLAG_TOGGLED
  CRON_MANUALLY_TRIGGERED
}

model PromptTemplate {
  id                 String                 @id @default(cuid())
  promptKey          String                 @unique
  feature            PromptFeature
  hdType             String?
  systemPrompt       String
  userPromptTemplate String
  bannedPhrases      String                 @default("")
  maxTokens          Int                    @default(800)
  temperature        Float                  @default(0.8)
  version            Int                    @default(1)
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  updatedBy          String

  history PromptTemplateVersion[]

  @@map("prompt_templates")
}

model PromptTemplateVersion {
  id               String         @id @default(cuid())
  promptTemplateId String
  systemPrompt     String
  userPromptTemplate String
  version          Int
  savedAt          DateTime       @default(now())
  savedBy          String

  promptTemplate PromptTemplate @relation(fields: [promptTemplateId], references: [id], onDelete: Cascade)

  @@index([promptTemplateId])
  @@map("prompt_template_versions")
}

model AuditLog {
  id         String          @id @default(cuid())
  timestamp  DateTime        @default(now())
  adminEmail String
  actionType AuditActionType
  targetId   String?
  targetType String?
  before     String?
  after      String?
  notes      String?

  @@index([adminEmail])
  @@index([actionType])
  @@index([timestamp])
  @@map("audit_logs")
}

model FeatureFlag {
  key       String   @id
  value     Boolean  @default(true)
  updatedAt DateTime @updatedAt
  updatedBy String

  @@map("feature_flags")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String

  @@map("system_configs")
}

model CronRun {
  id                String   @id @default(cuid())
  jobName           String
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  usersProcessed    Int      @default(0)
  insightsGenerated Int      @default(0)
  errorCount        Int      @default(0)
  errors            String?

  @@index([jobName])
  @@index([startedAt])
  @@map("cron_runs")
}

// ---------------------------------------------------------------------------
// REPORT MARKETPLACE — paid reports created by admin, generated by Gemini
// ---------------------------------------------------------------------------

enum ReportCategory {
  LIFE_PURPOSE
  CAREER
  RELATIONSHIPS
  SHADOW_WORK
  TIMING
  HEALTH
  FINANCE
  CUSTOM
}

enum ReportPurchaseStatus {
  PENDING
  PAID
  GENERATING
  COMPLETE
  FAILED
}

model ReportProduct {
  id            String   @id @default(cuid())
  slug          String   @unique // URL-safe identifier, e.g. "shadow-work-deep-dive"
  title         String
  subtitle      String?
  description   String   // Shown on the reports listing page
  category      ReportCategory
  priceUsd      Int // Stored in cents, e.g. 4900 = $49.00
  isActive      Boolean @default(true) // Admin can deactivate without deleting
  sortOrder     Int     @default(0)
  coverImageUrl String?
  geminiPrompt  String  // Supports placeholders: {{hd_type}}, {{hd_authority}}, ...
  estimatedWordCount Int @default(2000) // Shown to user as "~X word report"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String // Admin email who created it

  purchases     ReportPurchase[]
}

model ReportPurchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportProductId String
  reportProduct   ReportProduct @relation(fields: [reportProductId], references: [id], onDelete: Cascade)

  stripePaymentId String? @unique
  amountPaidUsd   Int // in cents
  status          ReportPurchaseStatus @default(PENDING)

  generatedReport GeneratedReport?

  purchasedAt     DateTime @default(now())

  @@unique([userId, reportProductId]) // one purchase per user per product
}

model GeneratedReport {
  id               String   @id @default(cuid())
  purchaseId       String   @unique
  purchase         ReportPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  content          String   // Full Gemini output, human-readable markdown
  wordCount        Int
  generatedAt      DateTime @default(now())
  geminiModel      String // e.g. "gemini-1.5-pro"
  generationTimeMs Int?
}
