node_modules
.next/

# Keep environment variables out of version control
# IMPORTANT: ALL .env variants must be listed here.
# Never commit secrets — rotate any key that appears in git history.
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

/app/generated/prisma

