/ephe/
*.se1

# SQLite local dev database
prisma/dev.db
prisma/dev.db-journal
prisma/dev.db-shm
prisma/dev.db-wal

# OS / editor noise
.DS_Store
**/.DS_Store

# Cursor debug logs
.cursor/*.log

# Local SQLite backups (never commit)
prisma/*.backup*

# Python bytecode
__pycache__/
*.py[cod]
